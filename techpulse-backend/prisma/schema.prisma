generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Global Cache for Analysis (Public)
model TechAnalysis {
  id        String   @id @default(uuid())
  techName  String   @unique
  metrics   Json
  aiInsight Json
  createdAt DateTime @default(now())
}

// User Accounts (Personalized)
model User {
  id        String          @id @default(uuid())
  email     String          @unique
  password  String
  history   SavedAnalysis[]
  savedArticles SavedArticle[]
  createdAt DateTime        @default(now())
}

// Personal History for Signed-up Users
model SavedAnalysis {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  techName  String
  createdAt DateTime @default(now())
}

// Saved News Articles
model SavedArticle {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  url       String
  source    String
  image     String?
  createdAt DateTime @default(now())
}

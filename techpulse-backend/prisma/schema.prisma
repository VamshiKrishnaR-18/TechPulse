generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// Global Cache for Analysis (Public)
model TechAnalysis {
  id        String   @id @default(uuid())
  techName  String   @unique
  metrics   Json
  aiInsight Json
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  history   SavedAnalysis[]
  savedArticles SavedArticle[]
  followedTechs Follow[]
  createdAt DateTime @default(now())
}

// User interests for personalized feed
model Follow {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  techName  String
  createdAt DateTime @default(now())

  @@unique([userId, techName])
}

// Personal History for Signed-up Users
model SavedAnalysis {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  techName  String
  createdAt DateTime @default(now())
}

// Saved News Articles
model SavedArticle {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  url       String
  source    String
  image     String?
  createdAt DateTime @default(now())
}
